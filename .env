# PharmaSUD Environment Configuration
# Stage 1 - Version 1.0.0
# Copy this file to .env.local for local development

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# Local PostgreSQL (Development)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pharmasud

# Railway PostgreSQL (Production) - Auto-filled by Railway
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# ============================================================
# SECURITY CONFIGURATION
# IMPORTANT: Change SECRET_KEY in production!
# Generate new key: openssl rand -hex 32
# ============================================================

SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ============================================================
# APPLICATION SETTINGS
# ============================================================

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# CORS Origins (comma-separated)
# In production, restrict to your domain only
ALLOWED_ORIGINS=*

# END - .env - Stage 1
