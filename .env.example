# PharmaSUD - Environment Configuration Example
# انسخ هذا الملف إلى .env وعدّل القيم

# قاعدة البيانات - PostgreSQL
# لـ Render.com: Dashboard > Environment Variables > DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# مفتاح التوقيع - غيّره بقوة!
# شغّل: openssl rand -hex 32
# يجب أن يكون 32 حرف هكسادسيمال على الأقل (64 حرف موصى به)
SECRET_KEY=a1b2c3d4e5f6789012345678901234567890abcdef1234567890abcdef123456

# الإعدادات
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# البيئة
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# CORS (استخدم عنوان URL المحدد في الإنتاج)
ALLOWED_ORIGINS=*